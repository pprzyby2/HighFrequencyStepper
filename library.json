{
  "name": "ESP32-HighFrequencyStepper",
  "version": "1.0.0",
  "description": "High-performance stepper motor controller for ESP32 with TMC2209/TMC2240 driver support, position feedback via ESP32Encoder, and LED status indication. Features dual-mode PWM generation (LEDC/Timer), multi-stepper support (up to 4 motors), StallGuard integration, and configurable acceleration profiles.",
  "keywords": [
    "stepper",
    "motor",
    "esp32",
    "tmc2209",
    "tmc2240",
    "pwm",
    "ledc",
    "encoder",
    "motion-control",
    "cnc"
  ],
  "authors": [
    {
      "name": "olimp",
      "maintainer": true
    }
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "license": "MIT",
  "frameworks": "arduino",
  "platforms": [
    "espressif32"
  ],
  "dependencies": {
    "TMCStepper": "*",
    "ESP32Encoder": "*",
    "adafruit/Adafruit NeoPixel": "^1.12.0"
  },
  "export": {
    "include": [
      "src/HighFrequencyStepper.h",
      "src/HighFrequencyStepper.cpp",
      "src/PWMStepper.h",
      "src/PWMStepper.cpp",
      "src/LEDStatusIndicator.h",
      "src/LEDStatusIndicator.cpp"
    ],
    "exclude": [
      "src/main.cpp",
      "src/test/*",
      "test/*"
    ]
  }
}
